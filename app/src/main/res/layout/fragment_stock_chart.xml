<?xml version="1.0" encoding="utf-8"?>
<!-- 
  股票模擬交易 - K線圖與下單面板佈局
  美化夜間簡約設計：支援 CombinedChart 混合圖表 (K線 + 均線)、十字指針數據連動區與緊湊排版
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">


        <!-- 緊湊型時間週期標籤 (Tab Style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:background="#2C2C2C">
            
            <TextView
                android:id="@+id/tab1D"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="走勢"
                android:gravity="center"
                android:padding="8dp"
                android:background="#2196F3"
                android:textColor="#FFFFFF" />
            <TextView
                android:id="@+id/tabDay"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="日線"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="#A0A0A0" />
            <TextView
                android:id="@+id/tabWeek"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="週線"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="#A0A0A0" />
            <TextView
                android:id="@+id/tabMonth"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="月線"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="#A0A0A0" />
        </LinearLayout>

        <!-- 
          【K 線 + 均線 混合圖表區塊 (CombinedChart)】
          - 將原先單純的 CandleStickChart 升級為 CombinedChart
          - 支援同時顯示 K線 與 MA5、MA20 均線折線
        -->
        <com.github.mikephil.charting.charts.CombinedChart
            android:id="@+id/candleChart"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginHorizontal="8dp" />

        <!-- 
          【十字指針即時連動數據區塊】 (新增)
          - 顯示格式: [價格 (漲跌幅%)]      座標: [時間 價格] [重置]
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:background="#1E1E1E"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp">

            <!-- 左側：即時現價與漲跌幅 (維持顯示即時行情，字體大一倍) -->
            <TextView
                android:id="@+id/tvStatsPricePercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- (--%)"
                android:textColor="#E0E0E0"
                android:textSize="@dimen/text_size_data_large"
                android:textStyle="bold" />

            <!-- 中間空白彈性填充 -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 右側：十字指針座標 (亮色，去掉括號) -->
            <TextView
                android:id="@+id/tvStatsCoordinates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" -- --"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_data_small"
                android:layout_marginEnd="6dp" />

            <!-- 重置按鈕：方塊狀小按鈕 -->
            <TextView
                android:id="@+id/btnResetCrosshair"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="重置"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_data_small"
                android:background="#2C2C2C"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ======================= -->
        <!-- 下單操作面板 (Order Panel) 夜間模式 -->
        <!-- ======================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#1E1E1E"
            android:layout_margin="12dp">

            <!-- Row 1: 該股未實現損益 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="該股未實現損益:"
                    android:textColor="#A0A0A0"
                    android:textSize="@dimen/text_size_data_medium" />
                    
                <TextView
                    android:id="@+id/tvUnrealizedPnl"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="***"
                    android:gravity="end"
                    android:textColor="#F44336"
                    android:textSize="@dimen/text_size_data_medium"
                    android:layout_marginEnd="8dp"/>
                    
                <TextView
                    android:id="@+id/tvUnrealizedPnlPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(+0.00%)"
                    android:textColor="#F44336"
                    android:textSize="@dimen/text_size_data_medium" />
            </LinearLayout>

            <!-- Row 2: 方塊狀切換 (買/賣 與 限/市) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                
                <!-- 買進/賣出 切換 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#2C2C2C"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:id="@+id/tabBuy"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="買進"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="#F44336"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_size_data_medium" />
                    <TextView
                        android:id="@+id/tabSell"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="賣出"
                        android:gravity="center"
                        android:padding="8dp"
                        android:textColor="#A0A0A0"
                        android:textSize="@dimen/text_size_data_medium" />
                </LinearLayout>

                <!-- 限價/市價 切換 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#2C2C2C">
                    <TextView
                        android:id="@+id/tabLimit"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="限價"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="#555555"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_size_data_medium" />
                    <TextView
                        android:id="@+id/tabMarket"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="市價"
                        android:gravity="center"
                        android:padding="8dp"
                        android:textColor="#A0A0A0"
                        android:textSize="@dimen/text_size_data_medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: 價格層 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp"
                android:background="#2C2C2C"
                android:padding="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="價格"
                    android:textColor="#A0A0A0"
                    android:textSize="@dimen/text_size_data_medium"
                    android:layout_marginEnd="8dp" />
                    
                <Button
                    android:id="@+id/btnMinusPrice"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="－"
                    android:padding="0dp"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF" />
                    
                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:text="0.00"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/text_size_data_medium"
                    android:background="@null" />
                    
                <Button
                    android:id="@+id/btnPlusPrice"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="＋"
                    android:padding="0dp"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                    
                <Button
                    android:id="@+id/btnFetchPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="取價"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="0dp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Row 4: 單位層 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:background="#2C2C2C"
                android:padding="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="單位"
                    android:textColor="#A0A0A0"
                    android:textSize="@dimen/text_size_data_medium"
                    android:layout_marginEnd="8dp" />
                    
                <Button
                    android:id="@+id/btnMinusQuantity"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="－"
                    android:padding="0dp"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF" />
                    
                <EditText
                    android:id="@+id/etQuantity"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="1"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/text_size_data_medium"
                    android:background="@null" />
                    
                <Button
                    android:id="@+id/btnPlusQuantity"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="＋"
                    android:padding="0dp"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF" />
                    
                <Button
                    android:id="@+id/btnPlus10Quantity"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="+10"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="0dp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Row 5: 試算區塊 (三排式置中表格布局，為餘額爭取最大寬度空間) -->
            <LinearLayout
                android:id="@+id/layoutEstimatesBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:background="#2C2C2C"
                android:padding="12dp">
                
                <!-- 標頭排 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical">
                    
                    <!-- 左列：狀態佔位 (寬度 50dp，留空) -->
                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="@dimen/text_size_data_medium" />
                    
                    <!-- 中間列：餘額標題 -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="3.5"
                        android:layout_height="wrap_content"
                        android:text="餘額"
                        android:textColor="#A0A0A0"
                        android:gravity="end"
                        android:layout_marginEnd="16dp"
                        android:textSize="@dimen/text_size_data_medium" />
                        
                    <!-- 右列：庫存標題 -->
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="0.9"
                        android:layout_height="wrap_content"
                        android:text="庫存"
                        android:textColor="#A0A0A0"
                        android:gravity="end"
                        android:textSize="@dimen/text_size_data_medium" />
                </LinearLayout>

                <!-- 當前排 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp"
                    android:gravity="center_vertical">
                    
                    <!-- 左列：當前標籤 -->
                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:text="當前"
                        android:textColor="#A0A0A0"
                        android:textSize="@dimen/text_size_data_medium" />
                    
                    <!-- 中間列：銀行餘額值 -->
                    <TextView
                        android:id="@+id/tvAccountBalance"
                        android:layout_width="0dp"
                        android:layout_weight="3.5"
                        android:layout_height="wrap_content"
                        android:text="*****"
                        android:gravity="end"
                        android:layout_marginEnd="16dp"
                        android:textColor="#A0A0A0"
                        android:textSize="@dimen/text_size_data_medium" />
                        
                    <!-- 右列：當前庫存值 -->
                    <TextView
                        android:id="@+id/tvInventory"
                        android:layout_width="0dp"
                        android:layout_weight="0.9"
                        android:layout_height="wrap_content"
                        android:text="*****"
                        android:gravity="end"
                        android:textColor="#A0A0A0"
                        android:textSize="@dimen/text_size_data_medium" />
                </LinearLayout>

                <!-- 成交排 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <!-- 左列：成交標籤 -->
                    <TextView
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:text="成交"
                        android:textColor="#A0A0A0"
                        android:textSize="@dimen/text_size_data_medium" />
                    
                    <!-- 中間列：預估成交餘額 -->
                    <TextView
                        android:id="@+id/tvEstBalance"
                        android:layout_width="0dp"
                        android:layout_weight="3.5"
                        android:layout_height="wrap_content"
                        android:text="*****"
                        android:gravity="end"
                        android:layout_marginEnd="16dp"
                        android:textColor="#03A9F4"
                        android:textSize="@dimen/text_size_data_medium" />
                        
                    <!-- 右列：預估成交庫存 -->
                    <TextView
                        android:id="@+id/tvEstInventory"
                        android:layout_width="0dp"
                        android:layout_weight="0.9"
                        android:layout_height="wrap_content"
                        android:text="*****"
                        android:gravity="end"
                        android:textColor="#03A9F4"
                        android:textSize="@dimen/text_size_data_medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 5: 送出與回報按鈕 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <Button
                    android:id="@+id/btnOrderReport"
                    android:layout_width="0dp"
                    android:layout_weight="0.4"
                    android:layout_height="wrap_content"
                    android:text="委託回報"
                    android:textSize="@dimen/text_size_data_medium"
                    android:backgroundTint="#555555"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                    
                <Button
                    android:id="@+id/btnSubmitOrder"
                    android:layout_width="0dp"
                    android:layout_weight="0.6"
                    android:layout_height="wrap_content"
                    android:text="確認下單"
                    android:textSize="@dimen/text_size_data_medium"
                    android:textStyle="bold"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
