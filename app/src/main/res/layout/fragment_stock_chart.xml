<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 頂部市價顯示 (夜間模式) -->
        <TextView
            android:id="@+id/tvCurrentPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#E0E0E0"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"/>

        <!-- 緊湊型時間標籤切換區 (Tab Style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:background="#2C2C2C">
            
            <TextView
                android:id="@+id/tab1D"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="當沖"
                android:gravity="center"
                android:padding="8dp"
                android:background="#2196F3"
                android:textColor="#FFFFFF" />
            <TextView
                android:id="@+id/tabDay"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="日線"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="#A0A0A0" />
            <TextView
                android:id="@+id/tabWeek"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="週線"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="#A0A0A0" />
            <TextView
                android:id="@+id/tabMonth"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="月線"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="#A0A0A0" />
        </LinearLayout>

        <!-- K 線圖表區塊 (夜間模式) -->
        <com.github.mikephil.charting.charts.CandleStickChart
            android:id="@+id/candleChart"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginHorizontal="8dp" />

        <!-- ======================= -->
        <!-- 下單操作面板 (Order Panel) 夜間模式 -->
        <!-- ======================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#1E1E1E"
            android:layout_margin="12dp">

            <!-- Row 1: 該股未實現損益 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="該股未實現損益:"
                    android:textColor="#A0A0A0"
                    android:textSize="14sp" />
                    
                <TextView
                    android:id="@+id/tvUnrealizedPnl"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="***"
                    android:gravity="end"
                    android:textColor="#F44336"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"/>
                    
                <TextView
                    android:id="@+id/tvUnrealizedPnlPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(+0.00%)"
                    android:textColor="#F44336"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Row 2: 方塊狀切換 (買/賣 與 限/市) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                
                <!-- 買進/賣出 切換 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#2C2C2C"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:id="@+id/tabBuy"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="買進"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="#F44336"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tabSell"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="賣出"
                        android:gravity="center"
                        android:padding="8dp"
                        android:textColor="#A0A0A0"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- 限價/市價 切換 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#2C2C2C">
                    <TextView
                        android:id="@+id/tabLimit"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="限價"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="#555555"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tabMarket"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="市價"
                        android:gravity="center"
                        android:padding="8dp"
                        android:textColor="#A0A0A0"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: 價格層 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp"
                android:background="#2C2C2C"
                android:padding="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="價格"
                    android:textColor="#A0A0A0"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />
                    
                <Button
                    android:id="@+id/btnMinusPrice"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="-"
                    android:padding="0dp"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF" />
                    
                <EditText
                    android:id="@+id/etPrice"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:text="0.00"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:background="@null" />
                    
                <Button
                    android:id="@+id/btnPlusPrice"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:padding="0dp"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                    
                <Button
                    android:id="@+id/btnFetchPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="取價"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="0dp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Row 4: 單位層 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:background="#2C2C2C"
                android:padding="8dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="單位"
                    android:textColor="#A0A0A0"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />
                    
                <Button
                    android:id="@+id/btnMinusQuantity"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="-"
                    android:padding="0dp"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF" />
                    
                <EditText
                    android:id="@+id/etQuantity"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:text="1"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:background="@null" />
                    
                <Button
                    android:id="@+id/btnPlusQuantity"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:padding="0dp"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF" />
                    
                <Button
                    android:id="@+id/btnPlus10Quantity"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="+10"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="0dp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Row 5: 試算區塊 (標題與數值分離、靠右對齊) -->
            <LinearLayout
                android:id="@+id/layoutEstimatesBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:background="#2C2C2C"
                android:padding="12dp">
                
                <!-- 交易前 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="銀行餘額"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvAccountBalance"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="*****"
                            android:gravity="end"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp" />
                    </LinearLayout>
                        
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="0.8"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="當前庫存"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvInventory"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="*****"
                            android:gravity="end"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 交易後 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="成交餘額"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvEstBalance"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="*****"
                            android:gravity="end"
                            android:textColor="#03A9F4"
                            android:textSize="14sp" />
                    </LinearLayout>
                        
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="0.8"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="成交庫存"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tvEstInventory"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="*****"
                            android:gravity="end"
                            android:textColor="#03A9F4"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 5: 送出與回報按鈕 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <Button
                    android:id="@+id/btnOrderReport"
                    android:layout_width="0dp"
                    android:layout_weight="0.4"
                    android:layout_height="wrap_content"
                    android:text="委託回報"
                    android:textSize="14sp"
                    android:backgroundTint="#555555"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                    
                <Button
                    android:id="@+id/btnSubmitOrder"
                    android:layout_width="0dp"
                    android:layout_weight="0.6"
                    android:layout_height="wrap_content"
                    android:text="確認下單"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
